            <textarea class="hex-editor" rows="2" id="cmd">7162000001064c45444241521000001055e0000003e810000010aae0000003e8200000</textarea>
            <div class="row h-end">
                <goo-btn
                    if:_="!this.runner?.running"
                    on:click="this.run()"
                    color="#0f5"
                >Run</goo-btn>
                <goo-btn
                    if:_="this.runner?.running"

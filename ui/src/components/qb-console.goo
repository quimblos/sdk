    </goo-modal>
</template>

<script>
public name = 'LEDBAR';
public leds = [true, false, true, false, true, false, true, false]

public output = '';

public setup() {
    qb.onLog(msg => {
        this.output += msg + '\n';
        this.$output.scrollTop = this.$output.scrollHeight;
        this.render();
    })
}

public open() {
    this.$modal.open();
}

private runner;

public async run() {
    this.output = '';
    this.runner = qb.makeRunner('console', this.$cmd.value);
    this.$cmd.value = '';
    this.runner.run();

